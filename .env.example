APP_ENV=dev
API_ENV=development
LOG_LEVEL=INFO
# Optional path mounted into container
DATA_DIR=/app/data
DATA_ROOT=/app/data
ENABLE_SYNC_ENDPOINTS=false
PROTECT_METRICS=false
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
# Set outside development/test. Never commit a real key.
API_KEY=
